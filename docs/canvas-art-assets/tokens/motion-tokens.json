    "cardHoverRisePx": 12
  },
  "divinationSequence": {
    "setup": 300,
    "buildupEnd": 2200,
    "climaxFreeze": 200,
    "resolutionEnd": 4500,
    "typingCharInterval": 60
  },
  "performanceCaps": {
    "activeShadowBlurInstances": 8,
    "idleParticles": [80, 120],
    "lowEndParticles": 50,
    "highEndBurstParticles": 300,
    "backgroundFps": 10,
    "mainFpsTarget": 60,
    "mainFpsFloor": 30
  },
  "reducedMotion": {
    "disable": ["glitch", "mouse trail", "burst particles", "large parallax"],
    "keep": ["static neon state", "core click feedback", "result reveal"]
  }
